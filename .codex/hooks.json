{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash '.codex/hooks/session-record-capture-previous-codex.sh'",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash '.codex/hooks/pre-bash-precheck.sh'",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
